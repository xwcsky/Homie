### Marek odznacza zadanie jako ZROBIONE (wymaga ID zadania, np. 1)
PATCH http://localhost:3000/tasks/2
Content-Type: application/json
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOjIsImVtYWlsIjoibWFyZWtAaG9taWUucGwiLCJpYXQiOjE3NzI1NTM2MjYsImV4cCI6MTc3MjU1NzIyNn0.qo-4uElHQEoG2OcFaYF4h4eghHmX7P-6VrE5QxuYKlk

{
  "isDone": true
}

